<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RoomLoom.Maui.Models"
             xmlns:vm="clr-namespace:RoomLoom.Maui.ViewModels"
             x:Class="RoomLoom.Maui.SessionsPage"
             x:DataType="vm:SessionsViewModel"
             Title="Sessions">

    <Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="10">

        <Label Grid.Row="0"
               Text="Upcoming sessions"
               Style="{StaticResource Headline}" />

        <Button Grid.Row="1"
                Text="Refresh"
                Command="{Binding LoadCommand}"
                HorizontalOptions="Start" />

        <Grid Grid.Row="2">

            <!-- Loading -->
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <VerticalStackLayout.Triggers>
                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding State}" Value="Loading">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </VerticalStackLayout.Triggers>
                <ActivityIndicator IsRunning="True" />
                <Label Text="Loading sessions..." HorizontalTextAlignment="Center" />
                <VerticalStackLayout.IsVisible>False</VerticalStackLayout.IsVisible>
            </VerticalStackLayout>

            <!-- Empty -->
            <Label Text="No upcoming sessions."
                   HorizontalOptions="Center" VerticalOptions="Center"
                   IsVisible="False">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding State}" Value="Empty">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>

            <!-- Error -->
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6"
                                 IsVisible="False">
                <VerticalStackLayout.Triggers>
                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding State}" Value="Error">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </VerticalStackLayout.Triggers>
                <Label Text="Couldn't load sessions" FontAttributes="Bold" TextColor="{StaticResource StatusError}" HorizontalTextAlignment="Center" />
                <Label Text="{Binding ErrorMessage}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Loaded -->
            <CollectionView x:Name="SessionsList"
                            ItemsSource="{Binding Sessions}"
                            SelectionMode="Single"
                            SelectionChanged="OnSessionSelected"
                            IsVisible="False">
                <CollectionView.Triggers>
                    <DataTrigger TargetType="CollectionView" Binding="{Binding State}" Value="Loaded">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </CollectionView.Triggers>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ScheduledSession">
                        <Border Style="{StaticResource Card}">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label>
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0:g} – {1:t}">
                                            <Binding Path="StartTime" />
                                            <Binding Path="EndTime" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding PlannedStatus}" TextColor="{StaticResource StatusScheduled}" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </Grid>

</ContentPage>
