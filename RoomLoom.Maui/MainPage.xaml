<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RoomLoom.Maui.ViewModels"
             x:Class="RoomLoom.Maui.MainPage"
             x:DataType="vm:ConnectionViewModel"
             Title="Connection">

    <ScrollView>
        <VerticalStackLayout Padding="30,40" Spacing="20">

            <Label Text="Connection — RoomLoom" Style="{StaticResource Headline}" />

            <Label Text="{Binding StatusText}" Style="{StaticResource StatusBadge}" />

            <Entry Text="{Binding SessionId, Mode=TwoWay}"
                   Placeholder="session id" />

            <Button Text="Connect &amp; Join"
                    Command="{Binding ConnectAndJoinCommand}"
                    HorizontalOptions="Fill" />

            <Label Text="Events:" FontAttributes="Bold" />

            <Border Style="{StaticResource Card}">
                <Label Text="{Binding EventsText}" LineBreakMode="WordWrap" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
